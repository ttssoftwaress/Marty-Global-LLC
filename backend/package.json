{
  "name": "marty-global-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "node --env-file-if-exists=.env ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node --env-file-if-exists=.env ./node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node --env-file-if-exists=.env ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:studio": "node --env-file-if-exists=.env ./node_modules/prisma/build/index.js studio",
    "db:seed": "tsx --env-file-if-exists=.env prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/client-ses": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@sentry/node": "^10.66.0",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.5",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.2",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}

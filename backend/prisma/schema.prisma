generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth ---------------------------------------------------------
// Managed by Better Auth (AGENTS.md "Auth"): the CLI generates these shapes;
// we only adapt ids/timestamps to project conventions. Better Auth supplies the
// row id, so no @default here. Timestamps are timestamptz UTC per AGENTS.md.
// Regenerate with: npx @better-auth/cli generate --config src/config/auth.ts

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime? @db.Timestamptz(3)
  country       String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt     DateTime? @db.Timestamptz(3)
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime @db.Timestamptz(3)
  token          String
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(3)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

// --- Notifications -------------------------------------------------------
// Every outbound email/SMS is a row first, then a queued job. The row is the
// delivery ledger: the processor claims it, sends, and records the provider
// reference, so a retried job is a no-op once the row is SENT.

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id        String              @id @default(cuid())
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  template  String
  // Recipient address (email or E.164 phone) — PII, never logged.
  recipient String
  subject   String?
  // Rendered at enqueue time so a retry sends byte-identical content.
  body      String
  bodyText  String?
  // Provider message id (SES MessageId / Twilio SID) once accepted.
  providerRef String?
  attempts  Int                 @default(0)
  lastError String?
  sentAt    DateTime?           @db.Timestamptz(3)
  userId    String?
  createdAt DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @db.Timestamptz(3)
  deletedAt DateTime?           @db.Timestamptz(3)

  @@index([status, createdAt])
  @@index([userId])
  @@map("notification")
}
